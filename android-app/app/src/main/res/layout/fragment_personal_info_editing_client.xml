<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/fragment_content"
    tools:context=".ui.fragments.profiles.PersonalInfoUpdateFragment">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/default_margin_padding"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="@dimen/default_margin_padding"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_10_top_curved_light_gray_borders_transparent_filled"
            android:orientation="vertical">


            <LinearLayout
                android:id="@+id/generalInfoTitleLL"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/dropdown_label_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/generalInfoTV"
                    style="@style/sub_title_textView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="0dp"
                    android:padding="10dp"
                    android:text="معلومات عامة"
                    android:textColor="@color/accent"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/personal_information_tv" />

                <View
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/generalInfoTitleIV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical|end"
                    android:padding="@dimen/default_margin_padding"
                    app:srcCompat="@drawable/end_dropdown_icon"
                    app:tint="#333333" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/generalInfoLL"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:orientation="vertical"
                android:padding="4dp"
                android:visibility="visible"
                tools:visibility="visible">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        style="@style/label_text_view"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/username"
                        android:textColor="@color/black"
                        android:textSize="18dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/user_name_TIL"
                        style="@style/TextInputLayout"
                        app:endIconTintMode="multiply"
                        app:startIconDrawable="@drawable/icon_user_data"
                        app:startIconTintMode="src_atop">

                        <com.google.android.material.textfield.TextInputEditText
                            style="@style/TextInputEditText"
                            android:hint="@string/username"
                            android:inputType="textPhonetic"
                            android:textSize="18sp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/first_name_tv"
                        style="@style/material_textView"
                        android:text="@string/first_name"
                        android:textColor="@color/black"
                        android:textSize="18sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/first_name_TIL"
                        style="@style/TextInputLayout"
                        android:layout_width="match_parent"

                        android:layout_height="wrap_content"
                        app:endIconTintMode="multiply"
                        app:startIconDrawable="@drawable/icon_user_data"
                        app:startIconTintMode="src_atop">

                        <com.google.android.material.textfield.TextInputEditText
                            style="@style/TextInputEditText"
                            android:hint="@string/first_name"
                            android:inputType="textPhonetic"
                            android:textSize="18sp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/second_name_tv"
                        style="@style/material_textView"
                        android:text="@string/last_name"
                        android:textColor="@color/black"
                        android:textSize="18sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/second_name_TIL"
                        style="@style/TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:endIconTintMode="multiply"
                        app:startIconDrawable="@drawable/icon_user_data"
                        app:startIconTintMode="src_atop">

                        <com.google.android.material.textfield.TextInputEditText
                            style="@style/TextInputEditText"
                            android:hint="@string/last_name"
                            android:inputType="textPhonetic"
                            android:textSize="18sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>


