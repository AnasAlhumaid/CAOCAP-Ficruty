<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/fragment_content"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.fragments.technicalSupport.TechSupportDetailFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView66"
                style="@style/material_textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تفاصيل التذكرة"
                android:textColor="@color/accent"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView

                style="@style/material_textView"
                android:id="@+id/idTV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:text="TJH- 0038845" />

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/default_margin_padding"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_20_curved_light_gray_borders_white_filled"
                android:orientation="horizontal"
                android:padding="@dimen/default_margin_padding">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                       


                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            style="@style/material_textView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="رقم التذكرة"
                            android:textColor="@color/accent"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/refranceNumberTV"
                            style="@style/material_textView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TJH- 0038845" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            style="@style/material_textView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="حالة التذكرة"
                            android:textColor="@color/accent"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/ticketSateTV"
                            style="@style/material_textView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="تم معالجة الطلب"
                            android:background="@drawable/bg_20_curved_border_light_green"


                            />
                    </LinearLayout>

                </LinearLayout>


                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            style="@style/material_textView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="نوع التذكرة"
                            android:textColor="@color/accent"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/ticketTypeTV"
                            style="@style/material_textView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="شكوى" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            style="@style/material_textView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="المحنوى"
                            android:textColor="@color/accent"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/ticketsDiscTV"
                            style="@style/material_textView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="تأخر تسليم مستحقات" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>


