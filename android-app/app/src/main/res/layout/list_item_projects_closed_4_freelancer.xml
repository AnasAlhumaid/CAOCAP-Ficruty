<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="1dp"
    tools:context=".ui.adapters.CompletedProjectsRV_AdapterForFreelancer"
    >

    <androidx.cardview.widget.CardView
        android:id="@+id/completedProCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="1dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toStartOf="@id/ongoingProCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_16_curved_gray_borders_transparent_filled"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="1dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_margin="1dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="1dp">

                <ImageView
                    android:id="@+id/userIV"
                    android:layout_width="75dp"
                    android:layout_height="75dp"
                    android:layout_margin="@dimen/list_item_margin_padding"
                    app:tint="@color/accent"
                    app:srcCompat="@drawable/client_cercular" />

                <TextView
                    android:id="@+id/clientNameTV"
                    style="@style/small_text_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:gravity="center"
                    android:text="Client Name"
                    android:textColor="@color/black" />

            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="?android:attr/listDivider" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="1dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="1dp">


                <TextView
                    style="@style/material_textView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:layout_margin="1dp"
                    android:text="مكتمل" />

                <TextView
                    android:id="@+id/projectTitleTV"
                    style="@style/material_textView"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_margin="1dp"
                    android:textDirection="rtl"
                    android:layout_weight="1"
                    android:text="Project Title"
                    android:textColor="@color/black" />

                <TextView
                    android:id="@+id/pubDateTV"
                    style="@style/small_text_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:textDirection="rtl"
                    android:text="Publication Date" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="1dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/textView7"
                        style="@style/small_text_view"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="1dp"
                        android:text="حالة الدفع:"
                        android:textColor="@color/black" />

                    <TextView
                        android:id="@+id/paymentStatusTV"
                        style="@style/small_text_view"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="1dp"
                        android:layout_weight="1"
                        android:text="Payment Status"
                        android:textColor="@color/black" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="@dimen/list_item_margin_padding">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/reviewBtn"
                        style="@style/primary_material_outlined_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_margin="@dimen/list_item_margin_padding"
                        android:text="تقييم"
                        app:icon="@drawable/rating_icon"
                        app:iconSize="25dp"
                        app:iconTint="@color/accent" />

                    <View
                        android:id="@+id/view8"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/detailsBtn"
                        style="@style/primary_material_btn"
                        android:layout_gravity="end"
                        android:layout_margin="@dimen/list_item_margin_padding"
                        android:drawableEnd="@drawable/baseline_accent_circle_arrow_24"
                        android:drawableTint="@android:color/transparent"
                        android:text="التفاصيل" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
