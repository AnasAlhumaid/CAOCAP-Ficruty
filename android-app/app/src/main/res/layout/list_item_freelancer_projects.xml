<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_margin="5dp"
app:cardCornerRadius="30dp"
    android:layoutDirection="rtl"
app:cardElevation="5dp">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_16_curved_gray_borders_transparent_filled"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="2dp">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/clientIV"
            style="@style/accent_image_view"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_margin="@dimen/list_item_margin_padding"
            android:background="@drawable/bg_oval_circle_accent_border_1"
            android:padding="6dp"
            app:srcCompat="@drawable/client_png" />

        <TextView
            android:id="@+id/projectTitleTV"
            style="@style/small_text_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:text="ترجمة"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView61"
            style="@style/small_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="المجال :" />

        <TextView
            android:id="@+id/serviceTypeTV"
            style="@style/small_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ترجمة" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView53"
            style="@style/small_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="0dp"
            android:text="تم إنجاز المشروع خلال"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/durationTV"
            style="@style/small_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="0dp"
            android:text="#"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/dayOrDaysTV"
            style="@style/small_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="0dp"
            android:text="أيام"
            android:textSize="12sp" />
    </LinearLayout>

    <Button
        android:id="@+id/detailsBtn"
        style="@style/primary_material_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="2dp"
        android:text="تفاصيل المشروع"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="start|center_vertical"
        android:orientation="horizontal"
        android:padding="4dp">



        <RatingBar
            android:id="@+id/ratingBar"
            style="@style/small_rating_bar_on_accent_bg"
            android:progressBackgroundTint="@color/gray_font"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/list_item_margin_padding"
            android:foregroundTint="@color/gray_font"
            android:rating="2" />

        <TextView
            style="@style/small_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="0dp"
            android:padding="0dp"
            android:text="(" />

        <TextView
            android:id="@+id/reviewNumberTV"
            style="@style/small_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="0dp"
            android:padding="0dp"
            android:text="0" />

        <TextView
            style="@style/small_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="0dp"
            android:padding="0dp"
            android:text=")" />
    </LinearLayout>


</LinearLayout>
</androidx.cardview.widget.CardView>

