<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/fragment_content"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingBottom="@dimen/system_nav_bar"
    tools:context=".ui.fragments.auth.signInOut.password.ForgetPasswordFragment">


    <LinearLayout
        android:id="@+id/emailCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            style="@style/material_textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:text="@string/enter_your_e_mail_address_to_reset_the_password"
            android:textColor="@color/accent"
            android:textSize="20sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/emailTIL"
            style="@style/TextInputLayout"
            android:layout_margin="8dp"
            app:endIconTintMode="multiply"
            app:startIconDrawable="@drawable/icon_email"
            app:startIconTintMode="src_atop">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/email_IET"
                style="@style/TextInputEditText"
                android:hint="@string/email"
                android:inputType="textEmailAddress"
                android:textSize="20sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backBtn"
            style="@style/material_textButton"
            android:layout_width="match_parent"
            android:layout_margin="8dp"
            android:text="عودة؟"
            android:textSize="20sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/password_reset_btn"
            style="@style/primary_material_btn"
            android:layout_width="match_parent"
            android:layout_margin="8dp"
            android:text="@string/send_password_reset_email"
            android:textSize="20sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/resetPasswordTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:fontFamily="@font/sakkal_majalla_bold"
        android:text="@string/forgetting_the_password"
        android:textColor="@color/accent"
        android:textSize="34sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="gone" />

    <LinearLayout

        android:id="@+id/resetCodeCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <!--                <com.google.android.material.textfield.TextInputLayout-->
        <!--                    android:layout_width="match_parent"-->
        <!--                    android:layout_height="match_parent"-->
        <!--                    android:layout_margin="4dp">-->

        <!--                    <com.google.android.material.textfield.TextInputEditText-->
        <!--                        android:id="@+id/email_IET"-->
        <!--                        android:layout_width="match_parent"-->
        <!--                        android:layout_height="wrap_content"-->
        <!--                        android:drawableStart="@drawable/message"-->
        <!--                        android:drawablePadding="3dp"-->
        <!--                        android:fontFamily="@font/sakkal_majalla"-->
        <!--                        android:hint="البريد الالكتروني"-->
        <!--                        android:inputType="textWebEmailAddress"-->
        <!--                        android:textSize="18dp" />-->
        <!--                </com.google.android.material.textfield.TextInputLayout>-->

        <TextView
            android:id="@+id/you_dont_have_account"

            style="@style/material_textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_margin="8dp"
            android:fontFamily="@font/sakkal_majalla_regular"
            android:padding="4dp"
            android:text="الرجاء ادخال الكود المرسل الى بريدك الشبكي"
            android:textColor="@color/accent"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="8dp"
            android:layoutDirection="ltr"
            android:orientation="horizontal"
            android:padding="8dp">

            <EditText
                android:id="@+id/d1ET"
                style="@style/appCompat_editText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:digits="0123456789"
                android:drawableTint="@color/gray_font"
                android:imeOptions="actionNext"
                android:inputType="number"
                android:maxLength="1"
                android:nextFocusForward="@id/d2ET"
                android:textAlignment="center"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/textView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="-"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/d2ET"
                style="@style/appCompat_editText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:digits="0123456789"
                android:drawableTint="@color/gray_font"
                android:imeOptions="actionNext"
                android:inputType="number"
                android:maxLength="1"
                android:nextFocusForward="@id/d3ET"
                android:textAlignment="center"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/textView6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="-"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/d3ET"
                style="@style/appCompat_editText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:digits="0123456789"
                android:drawableTint="@color/gray_font"
                android:imeOptions="actionNext"
                android:inputType="number"
                android:maxLength="1"
                android:nextFocusForward="@id/d4ET"
                android:textAlignment="center"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/textView9"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="-"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/d4ET"
                style="@style/appCompat_editText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:digits="0123456789"
                android:drawableTint="@color/gray_font"
                android:imeOptions="actionNext"
                android:inputType="number"
                android:maxLength="1"
                android:nextFocusForward="@id/d5ET"
                android:textAlignment="center"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/textView33"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="-"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/d5ET"
                style="@style/appCompat_editText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:digits="0123456789"
                android:drawableTint="@color/gray_font"
                android:imeOptions="actionNext"
                android:inputType="number"
                android:maxLength="1"
                android:nextFocusForward="@id/d6ET"
                android:textAlignment="center"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/textView35"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="-"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/d6ET"
                style="@style/appCompat_editText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:digits="0123456789"
                android:drawableTint="@color/gray_font"
                android:inputType="number"
                android:maxLength="1"
                android:textAlignment="center"
                android:textSize="20sp" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/back2Btn"
            style="@style/material_textButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:text="عودة؟"
            android:textSize="20sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/validateCodeBtn"
            style="@style/primary_material_btn"
            android:layout_width="match_parent"
            android:layout_margin="8dp"
            android:drawableEnd="@drawable/sharp_keyboard_arrow_right_24"
            android:text="@string/next"
            android:textSize="20sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>