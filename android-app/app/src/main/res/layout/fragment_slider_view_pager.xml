<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    tools:context=".ui.fragments.starter.ViewPagerFragment">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/ll"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">


    </androidx.viewpager2.widget.ViewPager2>

    <LinearLayout
        android:id="@+id/ll"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="2dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintBottom_toTopOf="@id/skipBtn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">


        <View
            android:id="@+id/v0"
            android:layout_width="@dimen/slide_indicator_size"
            android:layout_height="@dimen/slide_indicator_size"
            android:layout_margin="@dimen/slide_indicator_margin"
            android:background="@drawable/bg_5_curved_gray_dark_white_filled"/>

<!--        <View-->
<!--            android:id="@+id/v1"-->
<!--            android:layout_width="@dimen/slide_indicator_size"-->
<!--            android:layout_height="@dimen/slide_indicator_size"-->
<!--            android:layout_margin="@dimen/slide_indicator_margin"-->
<!--            android:background="@drawable/bg_5_curved_gray_dark_white_filled"/>-->

        <View
            android:id="@+id/v2"
            android:layout_width="@dimen/slide_indicator_size"
            android:layout_height="@dimen/slide_indicator_size"
            android:layout_margin="@dimen/slide_indicator_margin"
            android:background="@drawable/bg_5_curved_gray_dark_white_filled"/>
        <View
            android:id="@+id/v3"
            android:layout_width="@dimen/slide_indicator_size"
            android:layout_height="@dimen/slide_indicator_size"
            android:layout_margin="@dimen/slide_indicator_margin"
            android:background="@drawable/bg_5_curved_gray_dark_white_filled"/>
        <View
            android:id="@+id/v4"
            android:layout_width="@dimen/slide_indicator_size"
            android:layout_height="@dimen/slide_indicator_size"
            android:layout_margin="@dimen/slide_indicator_margin"
            android:background="@drawable/bg_5_curved_gray_dark_white_filled"/>
        <View
            android:id="@+id/v5"
            android:layout_width="@dimen/slide_indicator_size"
            android:layout_height="@dimen/slide_indicator_size"
            android:layout_margin="@dimen/slide_indicator_margin"
            android:background="@drawable/bg_5_curved_gray_dark_white_filled"/>
        <View
            android:id="@+id/v6"
            android:layout_width="@dimen/slide_indicator_size"
            android:layout_height="@dimen/slide_indicator_size"
            android:layout_margin="@dimen/slide_indicator_margin"
            android:background="@drawable/bg_5_curved_gray_dark_white_filled"/>


    </LinearLayout>

    <Button
        android:id="@+id/skipBtn"
        style="@style/Widget.AppCompat.Button.Borderless"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="2dp"
        android:text="@string/skip"
        android:textColor="@color/gray_font"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@id/divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginBottom="@dimen/system_nav_bar"
        android:background="?android:attr/listDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/skipBtn"
        app:layout_constraintStart_toStartOf="@+id/skipBtn" />

</androidx.constraintlayout.widget.ConstraintLayout>