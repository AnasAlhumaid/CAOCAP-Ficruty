<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/fragment_content"
    android:padding="0dp"
    android:paddingStart="0dp"
    android:paddingTop="0dp"
    android:paddingEnd="0dp"
    tools:context=".ui.fragments.freelancers.FreelancerProfileFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include layout="@layout/custom_app_bar_freelancer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            />

        <LinearLayout
            android:id="@+id/linearLayout5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profileHeader">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_squired_gray_borders_transparent_filled"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <TextView
                        style="@style/material_textView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/list_item_margin_padding"
                        android:text="إجمالي عدد الخدمات المكتملة"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/completedProCountTV"
                            style="@style/material_textView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="@dimen/list_item_margin_padding"
                            android:text="5"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/textView39"
                            style="@style/material_textView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="@dimen/list_item_margin_padding"
                            android:text="مشاريع مكتملة"
                            android:textSize="14sp" />
                    </LinearLayout>

                </LinearLayout>

                <View
                    style="@style/vertical_divider"
                    android:background="@color/divider_light_gray" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/textView41"
                        style="@style/material_textView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/list_item_margin_padding"
                        android:text="نطاق العمل"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView

                        android:id="@+id/serviceDomainsTV"
                        style="@style/material_textView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/list_item_margin_padding"
                        android:text="TextView"
                        android:textSize="14sp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/serviceDomainsRV"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:itemCount="3"
                        tools:listitem="@layout/list_item_freelancer_profile_domains" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/favouriteIV"
                    style="@style/accent_image_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_margin="10dp"
                    android:src="@drawable/favourite_btn_bg"
                    app:srcCompat="@drawable/favourite_btn_bg" />

            </LinearLayout>

            <View
                android:id="@+id/view14"
                android:layout_width="match_parent"
                android:layout_height="25dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/default_margin_padding"
                android:background="@drawable/input_drwable_bg_gray_borders_curved_5_transparent_filled"
                android:orientation="vertical">


                <TextView
                    style="@style/material_textView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:drawableStart="@drawable/presentation_slide"
                    android:text="نبذة عن مقدم الخدمة"
                    android:textColor="@color/accent"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/aboutTV"
                    style="@style/material_textView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="شركة اعلامية متخصصة بتقديم خدماتها الإنتاجية و التي تشمل أعمال التصوير التلفزيوني الإحترافي وأعمال (الجرافيك) و الهندسة الضوئية كما تقدم خدمات الدعاية و الإعلان من تصميم "
                    android:textSize="14sp" />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/default_margin_padding"
                android:background="@drawable/input_drwable_bg_gray_borders_curved_5_transparent_filled"
                android:orientation="vertical">


                <TextView
                    android:id="@+id/textView48"
                    style="@style/material_textView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/icon_bag"
                    android:text="الشهادات"
                    android:textColor="@color/accent"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/certificatesRV"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="3"
                    tools:listitem="@layout/list_item_freelancer_profile_certificates">

                </androidx.recyclerview.widget.RecyclerView>

                <TextView
                    android:id="@+id/certsTV"
                    style="@style/small_text_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="2dp"
                    android:text="لا توجد شهادات"
                    android:textSize="14sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/default_margin_padding"
                android:background="@drawable/input_drwable_bg_gray_borders_curved_5_transparent_filled"
                android:orientation="vertical">


                <TextView
                    style="@style/material_textView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/icon_files_on_hand"
                    android:text="مجالات مقدِّم الخدمة"
                    android:textColor="@color/accent"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/servicesRV"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="visible"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="3"
                    tools:listitem="@layout/list_item_freelancer_profile_services"
                    tools:visibility="gone" />

                <TextView
                    android:id="@+id/servicesTV"
                    style="@style/small_text_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="2dp"
                    android:text="لا توجد خدمات مسجلة"
                    android:textSize="14sp" />

            </LinearLayout>



        </LinearLayout>

<!--        <LinearLayout-->
<!--            android:id="@+id/certs_serLL"-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:layout_margin="4dp"-->
<!--            android:orientation="horizontal"-->
<!--            app:layout_constraintEnd_toEndOf="parent"-->
<!--            app:layout_constraintStart_toStartOf="parent"-->
<!--            app:layout_constraintTop_toBottomOf="@+id/linearLayout5">-->
<!--        </LinearLayout>-->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:orientation="vertical"
            android:padding="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/certs_serLL">

            <LinearLayout
                android:id="@+id/constraintLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:background="@drawable/input_drwable_bg_gray_borders_curved_5_transparent_filled"
                android:orientation="horizontal"
                app:layout_constraintBottom_toTopOf="@id/card_view"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/accomplishedProjectsTV"
                    style="@style/tab_item_sub_title"
                    android:background="@drawable/title_bg_selector_curved_accent_transparent_5"
                    android:text="الخدمات المنفذة"
                    android:textColor="@color/text_view_color_selector_accent_font_color" />

                <TextView
                    android:id="@+id/reviewsTV"
                    style="@style/tab_item_sub_title"
                    android:background="@drawable/title_bg_selector_curved_accent_transparent_5"
                    android:text="التقييمات"
                    android:textColor="@color/text_view_color_selector_accent_font_color" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/completedProRV"
                style="@style/recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:orientation="vertical"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                tools:itemCount="2"
                tools:listitem="@layout/list_item_freelancer_projects"
                tools:visibility="visible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/reviewsRV"
                style="@style/recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:orientation="vertical"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="2"
                tools:listitem="@layout/list_item_reviews"
                tools:visibility="gone" />

            <TextView
                android:id="@+id/noCompletedProTV"
                style="@style/small_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:padding="2dp"
                android:text="لا توجد بيانات"
                android:textSize="13sp"
                android:visibility="gone"
                tools:visibility="visible" />

        </LinearLayout>


    </LinearLayout>
</androidx.core.widget.NestedScrollView>
