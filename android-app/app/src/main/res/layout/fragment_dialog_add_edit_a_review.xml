<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@color/dialog_bg_dim"

    android:backgroundTintMode="add"

    android:layout_gravity="center"
    tools:context=".ui.fragments.reviews.AddEditReviewDialogFragment">

    <androidx.cardview.widget.CardView
        android:id="@+id/standard_bottom_sheet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_20_curved_borders_accent_filled"
            android:orientation="vertical"
            android:padding="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="4dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="4dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/material_textView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="0dp"
                        android:gravity="center"
                        android:paddingEnd="1dp"
                        android:text="تقييم"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/userType1TV"
                        style="@style/material_textView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="0dp"
                        android:gravity="center"
                        android:paddingStart="1dp"
                        android:text="مقدم الخدمة"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/cancelBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:scaleType="centerInside"
                    app:srcCompat="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="@color/white" />
            </LinearLayout>

            <View
                android:id="@+id/divider6"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#445a4e" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="4dp">

                <LinearLayout
                    style="@style/material_small_rating_bar_on_accent_bg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/textView91"
                            style="@style/material_textView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="2dp"
                            android:gravity="center"
                            android:text="تقييم"
                            android:textColor="@color/white"
                            android:textStyle="bold" />

                        <TextView
                            style="@style/material_textView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="2dp"
                            android:gravity="center"
                            android:text="مقدم الخدمة"
                            android:textColor="@color/white"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <RatingBar
                        android:id="@+id/ratingBar"
                        style="@style/rating_bar_on_dark_bg"

                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                         />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textView92"
                        style="@style/material_textView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="1dp"
                        android:paddingEnd="1dp"
                        android:text="التعليق على"
                        android:textColor="@color/white"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/userType2TV"
                        style="@style/material_textView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="1dp"
                        android:paddingStart="1dp"
                        android:text="طالب الخدمة"
                        android:textColor="@color/white"
                        android:textSize="18sp" />
                </LinearLayout>

                <EditText
                    android:id="@+id/commentTV"
                    style="@style/appCompat_editText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:gravity="top"
                    android:hint="التعليق على طالب الخدمة"
                    android:lines="3"
                    android:textColor="@color/white" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="vertical"
                    android:layout_height="wrap_content">

                    <TextView

                        style="@style/material_textView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="1dp"
                        android:paddingEnd="1dp"
                        android:text="تقييم خدمات المنصة"
                        android:textColor="@color/white"
                        android:textSize="18sp" />

                    <RatingBar
                        android:id="@+id/ratingBar2Website"

                        style="@style/rating_bar_on_dark_bg"

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/commentToWebsiteTV"
                        style="@style/appCompat_editText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="4dp"
                        android:gravity="top"
                        android:hint="اقتراحك يساعدنا على تطوير المنصة بشكل افضل لتلبية احتياجاتك"
                        android:lines="3"
                        android:textColor="@color/white" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/submitBtn"
                    style="@style/white_material_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp"
                    android:text="إرسال"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>



