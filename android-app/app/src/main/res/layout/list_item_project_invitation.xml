<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_margin="5dp"
app:cardCornerRadius="@dimen/card_curve_radius"
app:cardElevation="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_20_curved_gray_borders_transparent_filled"
        android:orientation="horizontal"
        android:padding="@dimen/default_margin_padding">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"

            >


            <ImageView
                android:id="@+id/userIV"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_margin="@dimen/projects_list_item_margins"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/company" />

            <TextView
                android:id="@+id/project_name_TV"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/projects_list_item_margins"
                android:drawablePadding="2dp"
                android:fontFamily="@font/sakkal_majalla"
                android:gravity="center|start"
                android:text="@string/project_name"
                android:textColor="@color/accent"
                android:textSize="16sp"
                android:textStyle="bold"

                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toEndOf="@+id/userIV"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/clientNameTV"
                style="@style/small_text_view"
                android:layout_width="0dp"
                android:layout_margin="0dp"
                android:text="شركة كاف الإعلامية"
                app:layout_constraintBottom_toTopOf="@id/freelancerLevelTV"
                app:layout_constraintEnd_toEndOf="@+id/project_name_TV"
                app:layout_constraintStart_toStartOf="@+id/project_name_TV"
                app:layout_constraintTop_toBottomOf="@+id/project_name_TV" />

            <TextView
                android:id="@+id/freelancerLevelTV"
                style="@style/small_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/list_item_margin_padding"
                android:drawableStart="@drawable/new_bag"
                android:text="Freelancer Level"
                app:layout_constraintBottom_toTopOf="@id/durationTV"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/userIV" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/durationTV"
                style="@style/small_text_view"
                android:layout_margin="@dimen/list_item_margin_padding"
                android:drawableStart="@drawable/new_calender"
                android:text="#"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/freelancerLevelTV" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/durationTV2"
                style="@style/small_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/list_item_margin_padding"
                android:text="أيام"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="@+id/durationTV"
                app:layout_constraintStart_toEndOf="@+id/durationTV"
                app:layout_constraintTop_toTopOf="@+id/durationTV" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/list_item_margin_padding"
                android:orientation="horizontal"
                android:padding="@dimen/list_item_margin_padding"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/durationTV">

                <TextView
                    android:id="@+id/serviceTypeTV"
                    style="@style/small_text_view"
                    android:layout_margin="@dimen/list_item_margin_padding"
                    android:background="@drawable/bg_5_curved_light_gray_borders_transparent_filled"
                    android:padding="@dimen/default_margin_padding"
                    android:text="@string/content_writing"
                    android:textStyle="bold" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical|end"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical"
                android:paddingEnd="10dp">

                <ImageView
                    android:id="@+id/favoriteBtn"
                    style="@style/accent_image_view"
                    android:layout_width="25dp"
                    android:layout_height="30dp"
                    android:layout_margin="@dimen/projects_list_item_margins"
                    android:src="@drawable/favourite_btn_bg"
                    app:srcCompat="@drawable/favourite_btn_bg" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_margin="@dimen/projects_list_item_margins"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/budget_TV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="1dp"
                        android:fontFamily="@font/sakkal_majalla"
                        android:gravity="center"
                        android:text="120"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/textView12"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="1dp"
                        android:fontFamily="@font/sakkal_majalla"
                        android:gravity="center"
                        android:text="@string/riyal"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/projects_list_item_margins"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:fontFamily="@font/sakkal_majalla"
                    android:gravity="center"
                    android:text="تقييم طالب الخدمة"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RatingBar
                    android:id="@+id/ratingBar2"
                    style="@style/material_small_rating_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <Button
                android:id="@+id/sendQuotationBtn"
                style="@style/primary_material_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/projects_list_item_margins"
                android:text="عرض التفاصيل"
                android:textAllCaps="false" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>

