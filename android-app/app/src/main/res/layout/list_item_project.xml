<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/default_margin_padding"
    android:padding="@dimen/list_item_margin_padding"
    android:layoutDirection="rtl"

    app:cardCornerRadius="20dp"
    app:cardElevation="5dp"
    app:chainUseRtl="false"

    app:guidelineUseRtl="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textDirection="rtl"


        android:background="@drawable/bg_20_curved_gray_borders_white_filled"
        android:orientation="vertical"



        android:padding="@dimen/default_margin_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/list_item_margin_padding"

                android:layout_weight="1"
                android:padding="@dimen/list_item_margin_padding">


                <ImageView
                    android:id="@+id/clientIV"
                    android:layout_width="60dp"
                    android:layout_height="55dp"
                    android:layout_margin="@dimen/list_item_margin_padding"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/company" />

                <TextView
                    android:id="@+id/project_name_TV"
                    style="@style/material_textView"
                    android:layout_width="0dp"
                    android:layout_margin="0dp"
                    android:text="@string/project_name"
                    android:textColor="@color/accent"
                    android:textDirection="rtl"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@+id/clientIV"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/clientIV"
                    app:layout_constraintTop_toTopOf="@+id/clientIV" />

                <TextView
                    android:id="@+id/clientNameTV"
                    style="@style/small_text_view"
                    android:layout_width="0dp"
                    android:layout_margin="0dp"
                    android:text="شركة كاف الإعلامية"
                    app:layout_constraintBottom_toTopOf="@id/freelancerLevelTV"
                    app:layout_constraintEnd_toEndOf="@+id/project_name_TV"
                    app:layout_constraintStart_toStartOf="@+id/project_name_TV"
                    app:layout_constraintTop_toBottomOf="@+id/project_name_TV" />

                <TextView
                    android:id="@+id/freelancerLevelTV"
                    style="@style/small_text_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/list_item_margin_padding"
                    android:drawableStart="@drawable/new_bag"
                    android:text="Freelancer Level"
                    app:layout_constraintBottom_toTopOf="@id/durationTV"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/clientNameTV" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/durationTV"
                    style="@style/small_text_view"
                    android:layout_margin="@dimen/list_item_margin_padding"
                    android:drawableStart="@drawable/new_calender"
                    android:text="#"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/freelancerLevelTV" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/durationTV2"
                    style="@style/small_text_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/list_item_margin_padding"
                    android:text="أيام"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="@+id/durationTV"
                    app:layout_constraintStart_toEndOf="@+id/durationTV"
                    app:layout_constraintTop_toTopOf="@+id/durationTV" />

                <LinearLayout
                    android:id="@+id/linearLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/list_item_margin_padding"
                    android:orientation="horizontal"
                    android:padding="@dimen/list_item_margin_padding"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/durationTV">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/specialityRV3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layoutDirection="locale"
                        android:orientation="horizontal"
                        android:textDirection="locale"
                        tools:itemCount="1"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/list_domaidn_on_project" />




                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:orientation="vertical"

                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/linearLayout">

                    <TextView
                        android:id="@+id/waitingTV"
                        style="@style/small_text_view"



                        android:text="sjndbxsjnxlaskjnx"
                        android:textStyle="bold" />


                </LinearLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/list_item_margin_padding"
                android:gravity="center|center_horizontal"
                android:orientation="vertical"
                android:padding="@dimen/list_item_margin_padding">

                <ImageView
                    android:id="@+id/favoriteBtn"
                    style="@style/accent_image_view"
                    android:layout_width="30dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_margin="5dp"
                    android:padding="5dp"
                    app:srcCompat="@drawable/favourite_btn_bg"
                    app:tint="@color/accent" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_margin="5dp"
                    android:orientation="horizontal"
                    android:padding="@dimen/list_item_margin_padding">

                    <TextView
                        android:id="@+id/budget_TV"
                        style="@style/small_text_view"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="0dp"
                        android:fontFamily="@font/sakkal_majalla"
                        android:text="120"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/textView12"
                        style="@style/small_text_view"
                        android:layout_margin="0dp"
                        android:fontFamily="@font/sakkal_majalla"
                        android:text="@string/riyal"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </LinearLayout>

                <Button
                    android:id="@+id/sendQuotationBtn"
                    style="@style/primary_material_btn"
                    android:layout_width="wrap_content"
                    android:layout_margin="@dimen/list_item_margin_padding"
                    android:backgroundTint="@color/accent"
                    android:text="@string/send_quotation" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/list_item_margin_padding"
                    android:orientation="vertical"
                    android:padding="@dimen/list_item_margin_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="0dp"
                        android:fontFamily="@font/sakkal_majalla"
                        android:gravity="center"
                        android:text="عدد العروض المقدمة : "
                        android:textSize="14sp"
                        android:textStyle="normal"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/numberOfBidsTV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="0dp"
                        android:fontFamily="@font/sakkal_majalla"

                        android:layout_gravity="center"
                        android:text="120"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>


    </LinearLayout>
</androidx.cardview.widget.CardView>
