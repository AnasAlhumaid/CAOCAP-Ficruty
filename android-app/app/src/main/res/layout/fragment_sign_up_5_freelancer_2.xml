<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/fragment_content"
    android:paddingBottom="@dimen/system_nav_bar"
    tools:context=".ui.fragments.auth.signUp.freelancer.FreelancerRegistration3Education">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="5dp">

        <TextView
            android:id="@+id/textView2"
            style="@style/material_textView"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:text="@string/education"
            android:textColor="@color/accent"
            android:textSize="20sp"
            android:textStyle="bold" />

        <View style="@style/horizontal_divider" />



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="5dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    style="@style/material_textView"
                    android:labelFor="@id/spinnerFL"
                    android:text="@string/certificate_type"
                    android:textColor="@color/black"
                    android:textSize="18sp" />
                <TextView
                    style="@style/material_textView"
                    android:text="*"
                    android:textColor="@color/red"
                    android:textSize="18dp" />
            </LinearLayout>



            <LinearLayout
                android:id="@+id/spinnerFL"
                style="@style/spinner_container"
                android:layout_margin="5dp">

                <ImageView
                    android:id="@+id/imageView11"
                    style="@style/IconImageView"
                    app:srcCompat="@drawable/docs_over_hand" />

                <Spinner
                    android:id="@+id/certificateTypeSpnr"
                    style="@style/spinner"
                    android:layout_weight="1"
                    android:drawablePadding="2dp"
                    android:entries="@array/edu_cert_type" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="5dp"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="5dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    style="@style/material_textView"
                    android:text="@string/institute_name"
                    android:textColor="@color/black"
                    android:textSize="18sp" />
                <TextView
                    style="@style/material_textView"
                    android:text="*"
                    android:textColor="@color/red"
                    android:textSize="18dp" />
            </LinearLayout>



            <EditText
                android:id="@+id/universityNameET"
                style="@style/appCompat_editText"

                android:drawableStart="@drawable/icon_univercity"
                android:hint="@string/institute_name"
                android:padding="10dp"
                android:textSize="18dp" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="5dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    style="@style/material_textView"
                    android:text="تاريخ الالتحاق"
                    android:textColor="@color/black"
                    android:textSize="18sp" />
                <TextView
                    style="@style/material_textView"
                    android:text="*"
                    android:textColor="@color/red"
                    android:textSize="18dp" />
            </LinearLayout>



            <EditText
                android:id="@+id/enrollmentDateET"
                style="@style/appCompat_editText"
                android:drawableStart="@drawable/icon_calender"
                android:hint="سنة الالتحاق"
                android:inputType="number"
                android:padding="10dp"
                android:textSize="18sp" />
        </LinearLayout>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="5dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    style="@style/material_textView"
                    android:text="تاريخ التخرج"
                    android:textColor="@color/black"
                    android:textSize="18sp" />
                <TextView
                    style="@style/material_textView"
                    android:text="*"
                    android:textColor="@color/red"
                    android:textSize="18dp" />
            </LinearLayout>



            <EditText
                android:id="@+id/graduationDateET"
                style="@style/appCompat_editText"
                android:drawableStart="@drawable/icon_calender"
                android:hint="سنة التخرج"
                android:inputType="date"
                android:padding="10dp"
                android:textSize="18sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="5dp"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="5dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/sakkal_majalla_regular"
                    android:text="إضافة شهادة PDF"
                    android:textColor="@color/black"
                    android:textSize="18sp" />
                <TextView
                    style="@style/material_textView"
                    android:text="*"
                    android:textColor="@color/red"
                    android:textSize="18dp" />
            </LinearLayout>



        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">


            <TextView
                android:id="@+id/f0Name"
                style="@style/material_textView"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="xxx.pdf"
                android:textColor="@color/black"
                android:textSize="18dp" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_file_btn"
                style="@style/primary_material_btn"
                android:text="@string/add_a_file"
                android:textSize="18sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_certificate_btn"
                style="@style/secondary_material_btn_black"
                android:text="@string/add_a_cert"
                android:textSize="18sp"
                app:icon="@drawable/baseline_add_24" />


        </LinearLayout>

        <TextView
            style="@style/material_textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="* يجب أن لا يتجاوز حجم الملف \u0662 م.ب." />

        <View style="@style/horizontal_divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="5dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button5"
                style="@style/secondary_material_btn"
                android:padding="10dp"
                android:text="السابق"
                android:textSize="20sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/next_btn"
                style="@style/primary_material_btn"
                android:padding="10dp"
                android:text="@string/next"
                android:textSize="20sp" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>