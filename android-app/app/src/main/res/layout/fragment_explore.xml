        <LinearLayout
            android:id="@+id/constraintLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_5_curved_accent_borders_transparent_filled"
            android:orientation="horizontal"
            android:layout_margin="5dp"
            app:layout_constraintBottom_toTopOf="@id/AddButtonLL"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/freelancers_tab"
                style="@style/tab_item_sub_title"
                android:background="@drawable/title_bg_selector_curved_accent_transparent_5"
