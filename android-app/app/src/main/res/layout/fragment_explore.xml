                android:textColor="@color/text_view_color_selector_accent_font_color" />

            <TextView
                android:id="@+id/projects_tab"
                style="@style/tab_item_sub_title"
                android:background="@drawable/title_bg_selector_curved_accent_transparent_5"
                android:text="الخدمات"
                android:textColor="@color/text_view_color_selector_accent_font_color" />


        </LinearLayout>
        <LinearLayout
            android:id="@+id/AddButtonLL"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:layout_margin="5dp"

            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintBottom_toTopOf="@id/browsingItems"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <Button
                android:id="@+id/AddButton"
                style="@style/primary_material_btn"
                android:layout_width="wrap_content"

                android:layout_height="wrap_content"


                android:text="طلب خدمة +"


                >

            </Button>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/browsingItems"
            android:layout_width="match_parent"
            android:layout_height="800dp"
            android:background="@color/fragment_bg_color"
            android:orientation="vertical">

