    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="1dp"
            android:visibility="visible">

            <TextView
                android:id="@+id/textView8"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="1dp"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="1dp"
                android:text="@string/classification_of_freelancers_by"
                android:textColor="@color/gray_font"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/clearBtn"
                style="@style/material_textButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="1dp"
                android:fontFamily="@font/sakkal_majalla"
                android:padding="4dp"
                android:text="@string/clear_results"
                android:textColor="@color/accent"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/serviceTitleLL"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:orientation="horizontal"
            android:focusable="true">

            <TextView
                android:id="@+id/serviceTV"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:layout_weight="1"
                android:padding="4dp"
                android:text="@string/domain"
                android:textColor="@color/accent"
                android:textSize="17sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/serviceTitleIV"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:padding="@dimen/default_margin_padding"
                app:srcCompat="@drawable/end_dropdown_icon"
                app:tint="#333333" />
        </LinearLayout>



        <LinearLayout
            android:id="@+id/servicesLL"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layoutDirection="rtl"
            android:visibility="gone"
            tools:visibility="visible">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                style="@style/recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layoutDirection="rtl"
                app:chainUseRtl="false"
                app:guidelineUseRtl="false"


                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"

                tools:itemCount="2"
                tools:listitem="@layout/list_item_grid_filters" />
        </LinearLayout>

