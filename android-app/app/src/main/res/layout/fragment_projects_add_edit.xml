<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/fragment_content"
    tools:context=".ui.fragments.projects.client.addEditProject.AddEditProject1Fragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/default_margin_padding"
        android:orientation="vertical"

        android:padding="@dimen/default_margin_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:orientation="vertical"
           >
<LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal">
    <TextView
        style="@style/label_text_view"
        android:labelFor="@id/projectTitle"
        android:textColor="@color/black"
        android:text="@string/project_title" />

    <TextView
        style="@style/material_textView"
        android:text="*"
        android:textColor="@color/red"
        android:textSize="18dp" />

</LinearLayout>

                <EditText
                    android:id="@+id/projectTitle"
                    style="@style/appCompat_editText"
                   android:background="@drawable/input_focuswd"

                    android:drawableStart="@drawable/presentation_slide"
                    android:hint="@string/project_title"
                    android:inputType="text"
                    android:maxLength="30" />




            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    style="@style/small_text_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:text="عدد الحروف المتاحة" />

                <TextView
                    android:id="@+id/ttl_char_TV"
                    style="@style/small_text_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:text="0" />

                <TextView
                    style="@style/small_text_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:text="/" />

                <TextView
                    android:id="@+id/ttlMax"
                    style="@style/small_text_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:text="30" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout


            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:gravity="center_vertical"
            android:orientation="vertical"
            >

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/domans_tv"
                    style="@style/label_text_view"
                    android:text="المجال"
                    android:textColor="@color/black"
                    android:textSize="18dp" />
                <TextView
                    style="@style/material_textView"
                    android:text="*"
                    android:textColor="@color/red"
                    android:textSize="18dp" />
            </LinearLayout>



            <FrameLayout
                android:id="@+id/domainsSpinnerFL"
                style="@style/spinner_container"
               >

                <Spinner
                    android:id="@+id/domains_spinner"
                    style="@style/spinner"
                android:layout_height="40dp"


                    android:fontFamily="@font/sakkal_majalla"

tools:listitem="@layout/fragment_custom_spinner"
                    android:textDirection="rtl"

                    />
            </FrameLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/specialityRV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layoutDirection="locale"
                android:orientation="horizontal"
                android:textDirection="locale"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/list_item_domain" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:orientation="vertical"
            >
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/textView23"
                    style="@style/label_text_view"
                    android:textColor="@color/black"
                    android:labelFor="@id/aboutProjectET"
                    android:text="@string/about_the_project" />
                <TextView
                    style="@style/material_textView"
                    android:text="*"
                    android:textColor="@color/red"
                    android:textSize="18dp" />
            </LinearLayout>



            <EditText
                android:id="@+id/aboutProjectET"
                style="@style/appCompat_editText"
                android:drawableStart="@drawable/feedback"
                android:hint="@string/about_the_project"
                android:inputType="textMultiLine"
                android:background="@drawable/input_focuswd"
                android:lines="2"
                android:maxLength="300" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    style="@style/small_text_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:text="عدد الحروف المتاحة" />

                <TextView
                    android:id="@+id/about_char_TV"
                    style="@style/small_text_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:text="0" />

                <TextView
                    style="@style/small_text_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:text="/" />

                <TextView
                    android:id="@+id/aboutMax"
                    style="@style/small_text_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:text="300" />
            </LinearLayout>

        </LinearLayout>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/uploadBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/primary_material_btn"
                android:backgroundTint="@color/divider_gray"
                android:text="ملف"
                android:textColor="@color/black"

                />

            <TextView
                style="@style/small_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="1dp"
                android:textColor="@color/divider_gray"
                android:text="نبذة مختصرة لتقييم الطلب من قبل مقدمي الخدمات" />

        </LinearLayout>
<TextView
    android:id="@+id/fileNameTextTV"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"


    />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:orientation="vertical"
            >

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/textView27"
                    style="@style/label_text_view"
                    android:textColor="@color/black"
                    android:labelFor="@id/expectedPriceET"
                    android:text="قيمة الخدمة المتوقعة" />

                <TextView
                    style="@style/material_textView"
                    android:text="*"
                    android:textColor="@color/red"
                    android:textSize="18dp" />
            </LinearLayout>



            <EditText
                android:id="@+id/expectedPriceET"
                style="@style/appCompat_editText"
                android:drawableStart="@drawable/icon_wallet"
                android:background="@drawable/input_focuswd"
                android:hint="@string/expected_price"
                android:inputType="numberDecimal" />
        </LinearLayout>

        <View
            style="@style/horizontal_divider"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="@color/gray_font" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/nextBtn"
            style="@style/primary_material_btn"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:padding="10dp"
            android:text="@string/next"
            android:textSize="18sp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

