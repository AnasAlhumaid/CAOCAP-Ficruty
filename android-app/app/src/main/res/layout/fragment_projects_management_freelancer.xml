<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/fragment_content"
    tools:context=".ui.fragments.projects.freelancer.ProjectsManagementFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/default_margin_padding"
        android:layout_marginBottom="@dimen/default_margin_padding"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/default_margin_padding"
            android:gravity="center"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:id="@+id/completedProCard"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/default_margin_padding"
                app:cardCornerRadius="20dp"
                app:cardElevation="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_20_curved_light_gray_borders_white_filled"
                    android:gravity="bottom"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:padding="1dp">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_margin="1dp"
                            android:background="@android:color/transparent"
                            android:backgroundTint="@android:color/transparent"
                            android:padding="@dimen/default_margin_padding"
                            android:src="@drawable/institute_project_accent_tint"
                            app:srcCompat="@drawable/institute_project_accent_tint"
                            app:tint="@color/accent" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="1dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="1dp">

                            <TextView
                                android:id="@+id/noCompletedProTV"
                                style="@style/material_textView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="1dp"
                                android:padding="@dimen/list_item_margin_padding"
                                android:text="0"
                                android:textColor="@color/accent"
                                android:textSize="16sp"
                                app:textLocale="ar" />

                            <TextView
                                style="@style/material_textView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="1dp"
                                android:padding="@dimen/list_item_margin_padding"
                                android:text="مشروع مكتمل"
                                android:textColor="@color/accent"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>

                    <View style="@style/horizontal_divider" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <Button

                            android:id="@+id/completedProBtn"
                            style="@style/primary_material_textBtn"
                            android:layout_gravity="end"
                            android:drawableEnd="@drawable/baseline_accent_circle_arrow_24"
                            android:drawableTint="@android:color/transparent"
                            android:text="التفاصيل" />
                    </FrameLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/ongoingProCard"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/default_margin_padding"
                app:cardCornerRadius="20dp"
                app:cardElevation="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_20_curved_light_gray_borders_white_filled"
                    android:gravity="bottom"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:padding="1dp">

                        <ImageView
                            android:id="@+id/imageView13"
                            style="@style/accent_image_view"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_margin="1dp"
                            android:padding="@dimen/default_margin_padding"
                            android:src="@drawable/institute_project_accent_tint"
                            app:srcCompat="@drawable/institute_project_accent_tint" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="1dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="1dp">

                            <TextView
                                android:id="@+id/noOngoingProTV"
                                style="@style/material_textView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="1dp"
                                android:padding="@dimen/list_item_margin_padding"
                                android:text="10"
                                android:textColor="@color/accent"
                                android:textSize="16sp" />

                            <TextView
                                style="@style/material_textView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="1dp"
                                android:padding="@dimen/list_item_margin_padding"
                                android:text="قيد التنفيذ"
                                android:textColor="@color/accent"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>

                    <View style="@style/horizontal_divider" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <Button
                            android:id="@+id/ongoingProBtn"
                            style="@style/primary_material_textBtn"
                            android:layout_gravity="end"
                            android:drawableEnd="@drawable/baseline_accent_circle_arrow_24"
                            android:drawableTint="@android:color/transparent"
                            android:text="التفاصيل" />
                    </FrameLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/default_margin_padding"
            android:gravity="center"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:id="@+id/bidsCard"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/default_margin_padding"
                app:cardCornerRadius="20dp"
                app:cardElevation="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_20_curved_light_gray_borders_white_filled"
                    android:gravity="bottom"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="bottom|center_horizontal"
                        android:orientation="horizontal"
                        android:padding="1dp">

                        <ImageView
                            android:id="@+id/imageView6"
                            style="@style/accent_image_view"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_margin="1dp"
                            android:padding="@dimen/default_margin_padding"
                            android:src="@drawable/institute_project_accent_tint"
                            app:srcCompat="@drawable/institute_project_accent_tint" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="1dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="1dp">

                            <TextView
                                android:id="@+id/noBidsTV"
                                style="@style/material_textView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="1dp"
                                android:padding="@dimen/list_item_margin_padding"
                                android:text="3"
                                android:textColor="@color/accent"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                style="@style/material_textView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="1dp"
                                android:padding="@dimen/list_item_margin_padding"
                                android:text="عروض مرسلة"
                                android:textColor="@color/accent"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>

                    <View style="@style/horizontal_divider" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <Button
                            android:id="@+id/bidsBtn"
                            style="@style/primary_material_textBtn"
                            android:layout_gravity="end"
                            android:drawableEnd="@drawable/baseline_accent_circle_arrow_24"
                            android:drawableTint="@android:color/transparent"
                            android:text="التفاصيل" />
                    </FrameLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/canceledProCard"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/default_margin_padding"
                app:cardCornerRadius="20dp"
                app:cardElevation="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_20_curved_light_gray_borders_white_filled"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            style="@style/accent_image_view"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_margin="1dp"
                            android:padding="@dimen/default_margin_padding"
                            app:srcCompat="@drawable/institution_projects" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="1dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="1dp">

                            <TextView
                                android:id="@+id/canceledProTV"
                                style="@style/material_textView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="1dp"
                                android:padding="@dimen/list_item_margin_padding"
                                android:text="0"
                                android:textColor="@color/accent"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                style="@style/material_textView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="1dp"
                                android:padding="@dimen/list_item_margin_padding"
                                android:text="مشروع ملغي"
                                android:textColor="@color/accent"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:id="@+id/view4"
                        style="@style/horizontal_divider" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <Button
                            android:id="@+id/canceledProBtn"
                            style="@style/primary_material_textBtn"
                            android:layout_gravity="end"
                            android:drawableEnd="@drawable/baseline_accent_circle_arrow_24"
                            android:drawableTint="@android:color/transparent"
                            android:text="التفاصيل" />
                    </FrameLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>


        <LinearLayout
            android:id="@+id/newProLL"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:padding="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/bidsCard">

            <TextView
                style="@style/sub_title_textView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:padding="8dp"
                android:text="المشاريع الحديثة"
                android:textColor="@color/accent"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/newProjectBidsRV"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:orientation="vertical"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="2"
                tools:listitem="@layout/list_item_new_projects_freelancer" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

