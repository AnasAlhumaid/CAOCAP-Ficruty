<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:padding="1dp"
    tools:context=".ui.adapters.OngoingProjectsFreelancerRVadapter">

    <androidx.cardview.widget.CardView
        android:id="@+id/completedProCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="1dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="1dp"
        app:layout_constraintEnd_toStartOf="@id/ongoingProCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_20_curved_gray_borders_transparent_filled"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/userIV"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:padding="2dp"
                    app:tint="@color/accent"
                    app:srcCompat="@drawable/client_cercular" />

                <TextView
                    android:id="@+id/clientNameTV"
                    style="@style/material_textView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="طالب الخدمة" />
            </LinearLayout>

            <View
                android:id="@+id/divider17"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="?android:attr/listDivider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="1dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="1dp">


                <TextView
                    style="@style/small_text_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:layout_margin="1dp"
                    android:text="قيد التنفيذ" />

                <TextView
                    android:id="@+id/projectTitleTV"
                    style="@style/material_textView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textDirection="rtl"
                    android:layout_margin="1dp"
                    android:text="Project Title"
                    android:textColor="@color/black" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:layout_margin="1dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="1dp">

                    <TextView
                        style="@style/small_text_view"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="1dp"
                        android:text="بداية الخدمة :" />

                    <TextView
                        android:id="@+id/projectStartDateTV"
                        style="@style/small_text_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="1dp"
                        android:text="Publication Date" />
                </LinearLayout>

                <View
                    android:id="@+id/divider16"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?android:attr/listDivider" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/textView104"
                                style="@style/small_text_view"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="المدة المتبقية لانهاء الخدمة :" />

                            <TextView
                                android:id="@+id/remainingDaysTV"
                                style="@style/small_text_view"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="#" />

                            <TextView
                                android:id="@+id/textView106"
                                style="@style/small_text_view"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="أيام" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView

                                style="@style/small_text_view"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="التكلفة" />

                            <TextView
                                android:id="@+id/costTV"
                                style="@style/small_text_view"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="#" />

                            <TextView
                                style="@style/small_text_view"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ر.س" />


                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
<LinearLayout
    android:layout_width="match_parent"
    android:gravity="end"
    android:layout_height="match_parent">

    <Button
        android:id="@+id/detailsBtn"
        style="@style/primary_material_textBtn"
        android:drawableEnd="@drawable/baseline_accent_circle_arrow_24"
        android:drawableTint="@android:color/transparent"

        android:text="التفاصيل"
        android:textSize="14sp" />
</LinearLayout>


            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
