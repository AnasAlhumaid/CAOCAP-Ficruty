                android:id="@+id/typeProject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:fontFamily="@font/sakkal_majalla"
                android:padding="4dp"
                android:text="تصنيف المشاريع"
                android:textColor="@color/accent"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_squired_gray_borders_transparent_filled"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="4dp">

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/waitingBidding"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checked="false"
                    android:layoutDirection="locale"
                    android:padding="4dp"
                    android:text="جارِ استقبال العروض"
                    android:textDirection="locale" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/stopBidding"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checked="false"
                    android:layoutDirection="locale"
                    android:padding="4dp"
                    android:text="متوقف عن استقبال العروض"
                    android:textDirection="locale" />
            </LinearLayout>

        </LinearLayout>


        <View
            style="@style/horizontal_divider"
            android:background="#e3e5e6" />

        <Button
            android:id="@+id/searchBtn"
            style="@style/primary_material_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="@string/search"
            android:textAllCaps="false"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
