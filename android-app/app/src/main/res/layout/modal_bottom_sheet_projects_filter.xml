                android:id="@+id/durationTV"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:layout_weight="1"
                android:padding="4dp"
                android:text="@string/milestone"
                android:textColor="@color/accent"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/durationTitleIV"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:padding="@dimen/default_margin_padding"
                app:srcCompat="@drawable/end_dropdown_icon"
                app:tint="#333333" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/milestoneLL"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_squired_gray_borders_transparent_filled"
            android:orientation="vertical"
            android:padding="4dp"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/dur_1_3_days_SW"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checked="false"
                    android:layoutDirection="rtl"
                    android:padding="4dp"
                    android:text="@string/_1_3_days"
                    android:textDirection="rtl" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/dur_1_5_days_SW"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layoutDirection="rtl"
                    android:padding="4dp"
                    android:text="@string/_1_5_days"
                    android:textDirection="rtl" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/dur_1_week_SW"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checked="false"
                    android:layoutDirection="rtl"
                    android:padding="4dp"
                    android:text="@string/_1_week"
                    android:textDirection="rtl" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/dur_1_3_week_SW"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layoutDirection="rtl"
                    android:padding="4dp"
                    android:text="@string/_1_3_weeks"
                    android:textDirection="rtl" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/dur_1_month_SW"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layoutDirection="rtl"
                    android:padding="4dp"
                    android:text="@string/_1_month"
                    android:textDirection="rtl" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/dur_2_3_monthes_SW"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layoutDirection="rtl"
                    android:padding="4dp"
                    android:text="@string/_2_3_months"
                    android:textDirection="rtl" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/dur_6_monthes_SW"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layoutDirection="rtl"
                    android:padding="4dp"
                    android:text="@string/_6_months"
                    android:textDirection="rtl" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/dur_les_year_SW"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layoutDirection="rtl"
                    android:padding="4dp"
                    android:text="@string/less_than_year"
                    android:textDirection="rtl" />

                <View
                    android:id="@+id/view"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
            </LinearLayout>
        </LinearLayout>

        <View
            style="@style/horizontal_divider"
            android:background="#e3e5e6" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_squired_gray_borders_transparent_filled"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">



        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

