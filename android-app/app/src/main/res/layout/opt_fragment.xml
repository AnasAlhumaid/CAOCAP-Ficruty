<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    tools:context=".ui.fragments.auth.OtpFragment"
    android:layout_height="match_parent">


    <LinearLayout

        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <EditText
            android:id="@+id/otpCheckTextE"
            style="@style/appCompat_editText"


            android:hint="@string/otp"
            android:inputType="number"
            android:textLocale="ar-SA"
            android:maxLength="30" />
           <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            >
            <TextView
                android:id="@+id/textView18"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="تم ارسال الرمز الى رقم جوالك المنتهي ب:" />
            <TextView
                android:id="@+id/textView182"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textDirection="ltr"
                android:padding="10dp"
                android:text="TextfvfvView" />
        </LinearLayout>



        <Button
            android:id="@+id/checkOtpBtn"
            android:layout_width="match_parent"
            android:backgroundTint="@color/accent"
            android:layout_height="wrap_content"
            android:text="@string/please_log_in" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>